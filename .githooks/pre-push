#!/usr/bin/env bash
# gaze-lens pre-push gate.
#
# Runs the same checks the release workflow would run, locally, before
# the push leaves your machine. Catches lint/format/test regressions
# without burning GitHub Actions minutes.
#
# Activate per clone (one-time):
#   git config core.hooksPath .githooks
#
# Emergency bypass (use sparingly — WIP backups only):
#   SKIP_HOOK=1 git push ...

set -euo pipefail

if [[ "${SKIP_HOOK:-0}" == "1" ]]; then
  echo "⚠  SKIP_HOOK=1 set — pre-push gate bypassed."
  echo "   You are pushing without running fmt/clippy/test locally."
  echo "   Only do this for WIP-branch backups; never for shared branches or tags."
  exit 0
fi

# --- docs-only fast-path -----------------------------------------------------
# Skip cargo gates when every changed file in this push matches a
# documentation/text allowlist. Saves several minutes on doc-only pushes
# (README tweaks, .claude/ skill updates, CHANGELOG additions, etc.).
#
# Allowlist is conservative: any unrecognized path triggers the full gate.
# Override with FORCE_FULL_GATE=1 git push to run gates anyway.

zero="0000000000000000000000000000000000000000"
push_has_refs=0
changed_files=""

while read -r local_ref local_sha remote_ref remote_sha; do
  push_has_refs=1
  if [[ "$local_sha" == "$zero" ]]; then
    continue
  fi
  if [[ "$remote_sha" == "$zero" ]]; then
    base=$(git merge-base "$local_sha" origin/main 2>/dev/null || echo "")
    if [[ -n "$base" ]]; then
      range_files=$(git diff --name-only "$base" "$local_sha")
    else
      range_files=$(git diff-tree --no-commit-id --name-only -r "$local_sha")
    fi
  else
    range_files=$(git diff --name-only "$remote_sha" "$local_sha")
  fi
  if [[ -n "$range_files" ]]; then
    changed_files+="${range_files}"$'\n'
  fi
done

if [[ "$push_has_refs" == "1" && "${FORCE_FULL_GATE:-0}" != "1" && -n "$changed_files" ]]; then
  is_docs_only=1
  non_doc_sample=""
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    case "$f" in
      *.md|*.txt|*.rst|*.adoc) ;;
      *.png|*.jpg|*.jpeg|*.gif|*.svg|*.webp|*.ico) ;;
      LICENSE|LICENSE-*|COPYING|NOTICE|AUTHORS|CODEOWNERS) ;;
      docs/*) ;;
      .claude/*|.ai/*) ;;
      AGENTS.md|CLAUDE.md|CHANGELOG.md|README.md|ROADMAP.md|CONTRIBUTING.md|SECURITY.md|GOVERNANCE.md) ;;
      .github/ISSUE_TEMPLATE/*|.github/PULL_REQUEST_TEMPLATE.md|.github/FUNDING.yml) ;;
      *)
        is_docs_only=0
        non_doc_sample="$f"
        break
        ;;
    esac
  done <<< "$changed_files"

  if [[ "$is_docs_only" == "1" ]]; then
    echo "▶  pre-push gate: docs-only push detected — skipping cargo gates."
    echo "   Override with FORCE_FULL_GATE=1 git push to run gates anyway."
    exit 0
  else
    echo "▶  pre-push gate: code change detected ($non_doc_sample) — running full gate."
  fi
fi
# --- end docs-only fast-path -------------------------------------------------

echo "▶  pre-push gate: cargo fmt --check"
if ! cargo fmt --check; then
  echo
  echo "✗  cargo fmt --check failed. Run 'cargo fmt' to fix, then push again."
  echo "   (Bypass with SKIP_HOOK=1 git push if you really mean it.)"
  exit 1
fi

echo "▶  pre-push gate: cargo clippy --all-targets --no-deps -- -D warnings"
if ! cargo clippy --all-targets --no-deps -- -D warnings; then
  echo
  echo "✗  cargo clippy failed. Fix warnings and push again."
  exit 1
fi

echo "▶  pre-push gate: cargo test --all-targets"
if ! cargo test --all-targets; then
  echo
  echo "✗  cargo test failed. Fix tests and push again."
  exit 1
fi

echo "✓  pre-push gate clean. Pushing."
